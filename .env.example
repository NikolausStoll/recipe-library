BACKEND_PORT=8097
DB_PATH=recipe-library.db
UPLOAD_DIR=/data/uploads
STATIC_DIR=/app/public
IMAGE_QUALITY=80
IMAGE_MAX_DIMENSION=2400
# Longest side for thumbnail previews (default 600)
THUMBNAIL_MAX_DIMENSION=600
# Longest side for recipe text images sent to OpenAI (only downscale; default 1400)
TEXT_IMAGE_MAX_DIMENSION=1400

# Perspective crop (4-point): backend/scripts/crop_perspective.py needs Python 3 + opencv-python + numpy. Optional: CROP_PYTHON=python3

# Recipe URL fetch (POST /api/recipes/extract-from-url): timeout ms, max response bytes, optional User-Agent
# RECIPE_URL_FETCH_TIMEOUT_MS=25000
# RECIPE_URL_MAX_BYTES=2000000
# RECIPE_URL_USER_AGENT=RecipeLibrary/1.0

# OpenAI: required for recipe text extraction (step 2 of import)
OPENAI_API_KEY=sk-…
# Optional: model for extract (default: gpt-4.1-mini)
OPENAI_EXTRACT_MODEL=gpt-4.1-mini
# Optional: detail for extract (default: high)
OPENAI_EXTRACT_DETAIL=high
# Optional: model for nutrition estimation (default: gpt-4o-mini)
OPENAI_NUTRITION_MODEL=gpt-4o-mini
# Optional: URL recipe normalization (POST /api/recipes/extract-from-url with normalize: true)
# OPENAI_NORMALIZE_MODEL_PRIMARY=gpt-4o-mini
# OPENAI_NORMALIZE_MODEL_FALLBACK=gpt-4.1-mini
# OPENAI_NORMALIZE_TEMPERATURE=0.2
