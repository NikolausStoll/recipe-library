BACKEND_PORT=8097
DB_PATH=recipe-library.db
UPLOAD_DIR=/data/uploads
STATIC_DIR=/app/public

# Image processing: quality, max dimension, thumbnail max dimension
IMAGE_QUALITY=80
IMAGE_MAX_DIMENSION=2400
TEXT_IMAGE_MAX_DIMENSION=1400
THUMBNAIL_MAX_DIMENSION=600

# Recipe URL fetch (POST /api/recipes/extract-from-url): timeout ms, max response bytes, optional User-Agent
RECIPE_URL_FETCH_TIMEOUT_MS=25000
RECIPE_URL_MAX_BYTES=2000000
RECIPE_URL_USER_AGENT=RecipeLibrary/1.0

# OpenAI: required for recipe text extraction (step 2 of import)
OPENAI_API_KEY=sk-…

# OpenAI: model for vision extract (default: gpt-4.1-mini)
OPENAI_EXTRACT_MODEL=gpt-4.1-mini
OPENAI_EXTRACT_DETAIL=high

# OpenAI: model for URL normalization (Recipe URL Extraction) (default: gpt-4o-mini)
OPENAI_NORMALIZE_MODEL_PRIMARY=gpt-4o-mini
OPENAI_NORMALIZE_TEMPERATURE=0.2

# Model and temperature for all other OpenAI LLM calls (default: gpt-4o-mini)
OPENAI_NUTRITION_MODEL=gpt-4o-mini
OPENAI_NUTRITION_MODEL_TEMPERATURE=0.2
OPENAI_HEALTH_SCORE_MODEL=gpt-4o-mini
OPENAI_HEALTH_SCORE_TEMPERATURE=0.2
OPENAI_TIME_ESTIMATE_MODEL=gpt-4o-mini
OPENAI_TIME_ESTIMATE_TEMPERATURE=0.2
OPENAI_RECIPE_TAG_MODEL=gpt-4o-mini
OPENAI_RECIPE_TAG_TEMPERATURE=0.2
