{
  "name": "recipe-library",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:backend": "npm --prefix backend run start",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:frontend:wait": "wait-on http://localhost:8097/api/health && npm run dev:frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend:wait\"",
    "build": "npm run build --workspace frontend",
    "start": "node backend/src/server.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "wait-on": "^9.0.4"
  }
}
